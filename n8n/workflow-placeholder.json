      "id": "telegram-trigger-demo",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [
        -1600,
        100
      ]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.message.chat.type }}",
              "rightValue": "private",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-private-chat-demo",
      "name": "IF Private Chat",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -1380,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const msg = $json.message || {};\nconst chat = msg.chat || {};\nconst from = msg.from || {};\n\nreturn [{\n  json: {\n    source: 'telegram_bot',\n    chat_id: chat.id,\n    user_id: from.id || null,\n    text: msg.text || '',\n    username: from.username || chat.username || null,\n    first_name: from.first_name || chat.first_name || null,\n    last_name: from.last_name || chat.last_name || null\n  }\n}];"
      },
      "id": "normalize-telegram-demo",
      "name": "Normalize Telegram Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1140,
        80
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT crm_process_tg_message('{{ JSON.stringify($json).replace(/'/g, \"''\") }}'::jsonb) AS result;",
        "options": {}
      },
      "id": "process-telegram-postgres-demo",
      "name": "Process Telegram in PostgreSQL",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -900,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $json.result || {};\nreturn [{\n  json: {\n    chat_id: r.chat_id || $('Normalize Telegram Message').item.json.chat_id,\n    reply_text: r.public_message || r.reply_text || 'Processing error.',\n    notify_owner: !!r.notify_owner,\n    owner_chat_id: r.owner_chat_id || null,\n    owner_group_chat_id: r.owner_group_chat_id || null,\n    owner_text: r.owner_text || null\n  }\n}];"
      },
      "id": "prepare-telegram-replies-demo",
      "name": "Prepare Telegram Replies",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -660,
        80
      ]
    },
