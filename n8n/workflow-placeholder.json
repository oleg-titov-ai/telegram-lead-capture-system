    {
      "parameters": {
        "jsCode": "const body = $json.body || $json || {};\n\nreturn [{\n  json: {\n    source: 'website_form',\n    client_slug: body.client_slug || 'demo-client',\n    product_type: body.product_type || null,\n    quantity: body.quantity || null,\n    delivery_address: body.delivery_address || null,\n    customer_name: body.customer_name || null,\n    customer_contact: body.customer_contact || null,\n    comment: body.comment || null,\n    page_url: body.page_url || null,\n    user_agent: $json.headers?.['user-agent'] || null,\n    personal_data_agree: body.personal_data_agree === true || body.personal_data_agree === 'true',\n    privacy_policy_url: body.privacy_policy_url || 'https://example.com/privacy.html',\n    consent_url: body.consent_url || 'https://example.com/consent.html'\n  }\n}];"
      },
